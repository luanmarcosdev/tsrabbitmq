{
  "name": "tsexp",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --runInBand",

    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/data-source.ts",
    "migration:create": "typeorm-ts-node-commonjs migration:create -d src/database/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",

    "worker:luan": "ts-node-dev --respawn --transpile-only src/workers/luan.worker.ts",
    "worker:order:wpp": "ts-node-dev --respawn --transpile-only src/workers/order.whatsapp.worker.ts",
    "worker:order:mail": "ts-node-dev --respawn --transpile-only src/workers/order.email.worker.ts",
    "worker:costumer:teste": "ts-node-dev --respawn --transpile-only src/workers/costumer.teste.worker.ts",
    "worker:test": "ts-node-dev --respawn --transpile-only src/workers/test.worker.ts"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "amqplib": "^0.10.9",
    "class-validator": "^0.14.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "mysql2": "^3.16.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.8",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.9.3"
  }
}
